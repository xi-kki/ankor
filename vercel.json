{
  "version": 2,
  "outputDirectory": ".",
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/config", "dest": "/api/config.js" },
    { "src": "/api/auth/verify", "dest": "/api/auth.js" },
    { "src": "/api/callback", "dest": "/api/callback.js" },
    { "src": "/api/chat", "dest": "/api/chat.js" },
    { "src": "/api/health", "dest": "/api/health.js" },
    { "src": "/api/middleware", "dest": "/api/middleware.js" },
    { "src": "/api/security", "dest": "/api/security.js" },
    { "src": "/manifest.json", "headers": { "Content-Type": "application/json" } },
    { "src": "/sw.js", "headers": { "Service-Worker-Allowed": "/" } },
    { "src": "/offline.html", "headers": { "Content-Type": "text/html" } },
    { "src": "/offline-storage.js", "headers": { "Content-Type": "application/javascript" } },
    { "src": "/offline-breathing.js", "headers": { "Content-Type": "application/javascript" } },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
