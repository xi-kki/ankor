{
  "version": 2,
  "outputDirectory": ".",
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/config", "dest": "/api/config.js" },
    { "src": "/api/auth/verify", "dest": "/api/auth.js" },
    { "src": "/api/callback", "dest": "/api/callback.js" },
    { "src": "/api/chat", "dest": "/api/chat.js" },
    { "src": "/api/health", "dest": "/api/health.js" },
    { "src": "/api/middleware", "dest": "/api/middleware.js" },
    { "src": "/api/security", "dest": "/api/security.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/manifest.json",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    }
  ]
}
