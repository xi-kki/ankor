{
  "name": "ankore",
  "version": "1.0.0",
  "description": "A voice-first AI wellness companion that's always available when you need someone to talk to.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "test": "echo \"No tests yet\" && exit 0",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx || true",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix || true",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check-all": "npm run lint && npm run format:check && npm test",
    "security": "npm audit --audit-level=high",
    "audit:fix": "npm audit fix",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ],
    "*.css": [
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xi-kki/ankore.git"
  },
  "keywords": [
    "wellness",
    "mental-health",
    "ai",
    "voice",
    "sui",
    "zklogin"
  ],
  "author": "Ankore",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/xi-kki/ankore/issues"
  },
  "homepage": "https://ankore.vercel.app",
  "dependencies": {
    "@vercel/kv": "^3.0.0",
    "express": "^5.2.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.11.1",
    "jose": "^6.0.11",
    "ws": "^8.21.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.0",
    "prettier": "^3.9.5"
  }
}
